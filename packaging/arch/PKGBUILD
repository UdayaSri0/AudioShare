pkgname=synchrosonic
pkgver=0.1.11
pkgrel=1
pkgdesc="Linux-first LAN audio streaming and casting application"
arch=('x86_64')
url="https://github.com/UdayaSri0/AudioShare"
license=('GPL-3.0-or-later')
depends=('gtk4' 'libadwaita' 'pipewire')
makedepends=('cargo' 'rust' 'pkgconf')
source=("${pkgname}-${pkgver}.tar.gz")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"
  cargo build --frozen --release -p synchrosonic-app
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 "target/release/synchrosonic-app" "${pkgdir}/usr/bin/synchrosonic-app"
  install -Dm644 "packaging/linux/org.synchrosonic.SynchroSonic.desktop" "${pkgdir}/usr/share/applications/org.synchrosonic.SynchroSonic.desktop"
  install -Dm644 "packaging/linux/org.synchrosonic.SynchroSonic.metainfo.xml" "${pkgdir}/usr/share/metainfo/org.synchrosonic.SynchroSonic.metainfo.xml"
  install -Dm644 "packaging/linux/org.synchrosonic.SynchroSonic.svg" "${pkgdir}/usr/share/icons/hicolor/scalable/apps/org.synchrosonic.SynchroSonic.svg"
  install -Dm644 "README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"
  install -Dm644 "LICENSE" "${pkgdir}/usr/share/doc/${pkgname}/LICENSE"
  install -Dm644 "docs/linux-packaging.md" "${pkgdir}/usr/share/doc/${pkgname}/linux-packaging.md"
}
